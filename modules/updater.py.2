import urllib.request
import json
import webbrowser
from tkinter import messagebox, simpledialog
import os

# ================== 配置区域 ==================
CURRENT_VERSION = "0.9.5"
PROJECT_URL = "https://gitee.com/yaopei6678/pymanager/releases"

# Gitee API 基础 URL
GITEE_API_BASE = "https://gitee.com/api/v5"

# 仓库完整路径（用户名/仓库名）
REPO_PATH = "yaopei6678/pymanager"

# Release API 地址
RELEASE_API_URL = f"{GITEE_API_BASE}/repos/{REPO_PATH}/releases/latest"

# 可选：使用代理列表（如果默认 API 不通可取消注释）
# PROXY_URLS = [
#     f"https://gh.api.99988866.xyz/{RELEASE_API_URL}",
#     f"https://github.moeyy.xyz/{RELEASE_API_URL}",
#     f"https://gh-proxy.com/{RELEASE_API_URL}",
# ]
# ===========================================

CONFIG_DIR = os.path.join(os.path.dirname(__file__), "..", "config")
TOKEN_FILE = os.path.join(CONFIG_DIR, "github_token.txt")  # 保留原有 Token 支持

def get_github_token():
    """从文件或环境变量获取 GitHub Token（Gitee 同理可复用）。"""
    if os.path.exists(TOKEN_FILE):
        with open(TOKEN_FILE, "r") as f:
            token = f.read().strip()
            if token:
                return token
    return os.environ.get("GITEE_TOKEN", "")

def save_github_token(token):
    """保存 Token 到文件。"""
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(TOKEN_FILE, "w") as f:
        f.write(token.strip())

def prompt_for_token(parent):
    """弹窗引导用户配置 Token。"""
    token = simpledialog.askstring(
        "Gitee Token",
        "为了提高 API 访问限额，请输入您的 Gitee Personal Access Token。\n\n"
        "如何获取？\n"
        "1. 访问 https://gitee.com/personal_access_tokens\n"
        "2. 点击 '生成新令牌'\n"
        "3. 为 Token 起一个名字（如 'pymanager'）\n"
        "4. 勾选 'projects' 权限（用于读取仓库 Release）\n"
        "5. 生成并复制 Token 后粘贴到此处。\n\n"
        "若跳过，程序将受匿名 IP 限制，每小时只能检查 60 次。（推荐配置 Token）\n"
        "是否现在配置一个 Token？",
        parent=parent
    )
    if token:
        save_github_token(token)
        return token
    return ""

def is_version_greater(v1, v2):
    try:
        a1 = [int(x) for x in v1.split('.')]
        a2 = [int(x) for x in v2.split('.')]
        max_len = max(len(a1), len(a2))
        a1 += [0] * (max_len - len(a1))
        a2 += [0] * (max_len - len(a2))
        return a1 > a2
    except Exception:
        return v1 > v2

def fetch_latest_version(parent=None):
    """
    从 Gitee API 获取最新版本号和下载链接。
    支持 Token 认证和代理回退机制。
    """
    token = get_github_token()
    if not token and parent:
        token = prompt_for_token(parent)

    headers = {
        "User-Agent": "PythonScriptManager/0.9.5",
        "Accept": "application/json"
    }
    if token:
        headers["Authorization"] = f"token {token}"
        auth_status = "已认证"
    else:
        auth_status = "未认证"

    # 备用代理列表（如需启用可取消注释）
    proxy_list = []  # 可以填充 PROXY_URLS
    urls_to_try = [RELEASE_API_URL] + proxy_list

    for url in urls_to_try:
        try:
            print(f"尝试访问: {url}")
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read().decode())
                # 提取版本号：优先使用 name，其次 tag_name
                latest = data.get("name") or data.get("tag_name", "")
                if latest.startswith("v"):
                    latest = latest[1:]
                # 提取下载链接（Gitee 的 assets 结构与 GitHub 类似）
                assets = data.get("assets", [])
                download = assets[0].get("browser_download_url") if assets else ""
                print(f"[{auth_status}] 获取版本成功: {latest}")
                return latest, download
        except Exception as e:
            print(f"请求失败: {e}")
            continue

    return None, None

def check_for_updates(parent_root=None, show_no_update_msg=True):
    latest, download_url = fetch_latest_version(parent_root)
    if latest is None:
        if show_no_update_msg:
            messagebox.showerror(
                "检查更新失败",
                f"无法获取最新版本信息，请检查网络连接或稍后重试。\n可直接访问项目主页查看：\n{PROJECT_URL}",
                parent=parent_root
            )
        return False
    if is_version_greater(latest, CURRENT_VERSION):
        msg = f"发现新版本 v{latest}（当前版本 v{CURRENT_VERSION}）\n\n是否前往下载页面？"
        if messagebox.askyesno("软件更新", msg, parent=parent_root):
            # 优先使用 API 返回的下载链接，否则跳转到项目主页
            webbrowser.open(download_url if download_url else PROJECT_URL)
        return True
    else:
        if show_no_update_msg:
            messagebox.showinfo("检查更新", f"当前已是最新版本 v{CURRENT_VERSION}", parent=parent_root)
        return False